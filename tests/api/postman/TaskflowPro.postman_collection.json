          "name": "A-01: Register Manager",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\"fullName\":\"Manager User\",\"email\":\"manager_{{$randomInt}}@example.com\",\"password\":\"SecurePass123!\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 201', () => pm.response.to.have.status(201));",
                "pm.collectionVariables.set('managerEmail', JSON.parse(pm.request.body.raw).email);"
              ]
            }
          }]
        },
