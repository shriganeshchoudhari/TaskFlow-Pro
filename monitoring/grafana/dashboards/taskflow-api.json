{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "TaskFlow Pro — API performance, JVM health, and database metrics",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Request Rate (req/s)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "orientation": "auto" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 200 }] }, "unit": "reqps" }, "overrides": [] },
      "targets": [{ "expr": "sum(rate(http_server_requests_seconds_count{application=\"taskflow-pro\"}[1m]))", "legendFormat": "Total", "refId": "A" }]
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Error Rate (5xx %)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "orientation": "auto" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] }, "unit": "percent", "max": 100 }, "overrides": [] },
      "targets": [{ "expr": "100 * sum(rate(http_server_requests_seconds_count{application=\"taskflow-pro\",status=~\"5..\"}[1m])) / sum(rate(http_server_requests_seconds_count{application=\"taskflow-pro\"}[1m]))", "legendFormat": "5xx %", "refId": "A" }]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "P95 Latency",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "orientation": "auto" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 200 }, { "color": "red", "value": 300 }] }, "unit": "ms" }, "overrides": [] },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"taskflow-pro\"}[5m])) by (le)) * 1000", "legendFormat": "P95", "refId": "A" }]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "JVM Heap Used",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "orientation": "auto" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 600000000 }, { "color": "red", "value": 900000000 }] }, "unit": "bytes" }, "overrides": [] },
      "targets": [{ "expr": "sum(jvm_memory_used_bytes{application=\"taskflow-pro\",area=\"heap\"})", "legendFormat": "Heap", "refId": "A" }]
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "API Latency Percentiles",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{application=\"taskflow-pro\"}[5m])) by (le)) * 1000", "legendFormat": "P50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"taskflow-pro\"}[5m])) by (le)) * 1000", "legendFormat": "P95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{application=\"taskflow-pro\"}[5m])) by (le)) * 1000", "legendFormat": "P99", "refId": "C" }
      ]
    },

    {
      "id": 6,
      "type": "timeseries",
      "title": "Request Rate by Endpoint",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "legend": { "calcs": ["mean"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 1 } }, "overrides": [] },
      "targets": [
        { "expr": "sum by (uri) (rate(http_server_requests_seconds_count{application=\"taskflow-pro\",uri!~\".*(actuator|swagger).*\"}[1m]))", "legendFormat": "{{uri}}", "refId": "A" }
      ]
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "HTTP Error Rate (4xx / 5xx)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "targets": [
        { "expr": "sum(rate(http_server_requests_seconds_count{application=\"taskflow-pro\",status=~\"4..\"}[1m]))", "legendFormat": "4xx", "refId": "A" },
        { "expr": "sum(rate(http_server_requests_seconds_count{application=\"taskflow-pro\",status=~\"5..\"}[1m]))", "legendFormat": "5xx", "refId": "B" }
      ]
    },

    {
      "id": 8,
      "type": "timeseries",
      "title": "JVM Memory — Heap & Non-Heap",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "targets": [
        { "expr": "sum(jvm_memory_used_bytes{application=\"taskflow-pro\",area=\"heap\"})",     "legendFormat": "Heap Used",     "refId": "A" },
        { "expr": "sum(jvm_memory_max_bytes{application=\"taskflow-pro\",area=\"heap\"})",      "legendFormat": "Heap Max",      "refId": "B" },
        { "expr": "sum(jvm_memory_used_bytes{application=\"taskflow-pro\",area=\"nonheap\"})", "legendFormat": "Non-Heap Used", "refId": "C" }
      ]
    },

    {
      "id": 9,
      "type": "timeseries",
      "title": "GC Pause Time",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "targets": [
        { "expr": "rate(jvm_gc_pause_seconds_sum{application=\"taskflow-pro\"}[1m])", "legendFormat": "{{action}} {{cause}}", "refId": "A" }
      ]
    },

    {
      "id": 10,
      "type": "timeseries",
      "title": "HikariCP Connection Pool",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "targets": [
        { "expr": "hikaricp_connections_active{application=\"taskflow-pro\"}",  "legendFormat": "Active",  "refId": "A" },
        { "expr": "hikaricp_connections_idle{application=\"taskflow-pro\"}",    "legendFormat": "Idle",    "refId": "B" },
        { "expr": "hikaricp_connections_pending{application=\"taskflow-pro\"}", "legendFormat": "Pending", "refId": "C" },
        { "expr": "hikaricp_connections_max{application=\"taskflow-pro\"}",     "legendFormat": "Max",     "refId": "D" }
      ]
    },

    {
      "id": 11,
      "type": "timeseries",
      "title": "Active JVM Threads",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "targets": [
        { "expr": "jvm_threads_live_threads{application=\"taskflow-pro\"}",   "legendFormat": "Live",   "refId": "A" },
        { "expr": "jvm_threads_daemon_threads{application=\"taskflow-pro\"}", "legendFormat": "Daemon", "refId": "B" },
        { "expr": "jvm_threads_peak_threads{application=\"taskflow-pro\"}",   "legendFormat": "Peak",   "refId": "C" }
      ]
    },

    {
      "id": 12,
      "type": "timeseries",
      "title": "CPU Usage",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "lineWidth": 2 } }, "overrides": [] },
      "targets": [
        { "expr": "process_cpu_usage{application=\"taskflow-pro\"}",  "legendFormat": "Process CPU",  "refId": "A" },
        { "expr": "system_cpu_usage{application=\"taskflow-pro\"}",   "legendFormat": "System CPU",   "refId": "B" }
      ]
    }

  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["taskflow", "api", "jvm"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "TaskFlow Pro — API & JVM",
  "uid": "taskflow-api-jvm",
  "version": 1
}
